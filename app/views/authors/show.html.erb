<h1><%= @author.name %></h1>

<h3>Books</h3>

<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th>Title</th>
      <th>Publisher</th>
      <th>Category</th>
      <th>Rating</th>
    </tr>
  </thead>

  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td>
          <%= link_to book.title, book_path(book) %>
        </td>

        <td><%= book.publisher.name %></td>

        <td><%= book.category.name %></td>

        <td><%= book.rating %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "← Back to Authors", authors_path, class: "btn btn-secondary" %>