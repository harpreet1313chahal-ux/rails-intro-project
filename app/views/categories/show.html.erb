<h1><%= @category.name %></h1>

<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th>Title</th>
      <th>Author</th>
      <th>Publisher</th>
      <th>Rating</th>
    </tr>
  </thead>

  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= link_to book.title, book_path(book) %></td>
        <td><%= book.author.name %></td>
        <td><%= book.publisher.name %></td>
        <td><%= book.rating %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "← Back to Categories", categories_path, class: "btn btn-secondary" %>